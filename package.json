{
  "name": "merge-minion",
  "version": "0.1.0",
  "private": true,
  "description": "Local daemon that auto-updates your GitHub PRs when they fall behind main, so Auto-merge can land them.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "merge-minion": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dry-run": "tsx src/index.ts --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
